# Jira Integration Configuration
# Copy this file to .env and fill in your values

# Jira credentials
# For Atlassian Cloud, use email and API token
# Create token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=your.email@example.com
JIRA_TOKEN=ATATT3xFfGF0xxxxxxxxxxxxxxxxxxxxxxxx

# Jira instance URL
JIRA_URL=https://yourdomain.atlassian.net

# Optional: Override project from config
# JIRA_PROJECT=PROJ
