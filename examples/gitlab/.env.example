# GitLab Integration Configuration
# Copy this file to .env and fill in your values

# GitLab Personal Access Token
# Create at: https://gitlab.com/-/profile/personal_access_tokens
# Required scopes: api, read_api, read_repository, write_repository
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab instance URL (use https://gitlab.com for GitLab.com)
GITLAB_URL=https://gitlab.com

# Optional: Override project ID from config
# GITLAB_PROJECT_ID=123456
